# LLM provider selection: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# API keys (fill in only the provider(s) you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LLM model overrides (optional; defaults are sensible)
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service_account.json
SPREADSHEET_ID=

# Tab names (override only if your sheet differs)
SOURCES_TAB_RU=Sources (RU)
SOURCES_TAB_UZ=Sources (UZ)
SOURCES_TAB_KZ=Sources (KZ)
NEWS_TAB=News
PUBLISHED_NEWS_TAB=Published news
SECTIONS_TAB=News sections
OUTPUT_TAB=News

# Pipeline knobs
FRESHNESS_HOURS=48
FUZZY_TITLE_THRESHOLD=0.85
DEFAULT_RATE_LIMIT_RPS=1.0
MAX_COST_USD=5.0
USER_AGENT=NewsMakerBot/0.1 (+https://example.com/bot)

# SQLite dedup cache
SQLITE_PATH=./data/news_agent.sqlite

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
